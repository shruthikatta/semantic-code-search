# Backend
ELASTICSEARCH_URL=http://elasticsearch:9200
ES_INDEX=code_chunks

# Embedding model loaded by sentence-transformers.
# Options:
#   jinaai/jina-embeddings-v2-base-code    (default, 768 dim, code-aware)
#   sentence-transformers/all-MiniLM-L6-v2 (faster, 384 dim; also update EMBEDDING_DIM below)
EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-code
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=32

# SECURITY: sentence-transformers will execute arbitrary Python from a model
# repository when this is true. The default model (jinaai/jina-embeddings-v2-base-code)
# requires it because of its custom JinaBERT architecture; switch to
# sentence-transformers/all-MiniLM-L6-v2 (or a similar non-custom model) if you
# want to keep this off. Never enable this for an untrusted EMBEDDING_MODEL.
EMBEDDING_TRUST_REMOTE_CODE=true

# Indexing
INDEX_BULK_CHUNK_SIZE=200

# Skip .py files larger than this (bytes). Guards against a pathological file
# OOMing the backend during chunking.
INDEXER_MAX_FILE_BYTES=2097152

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Backend CORS allow-list (comma-separated). Keep tight for a local-only tool;
# add your deploy origin if you serve the UI from somewhere else.
CORS_ORIGINS=http://localhost:3000
